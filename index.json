  "plugins": [
    {
      "name": "om-node-monitor",
      "version": "1.0.0",
      "display_name": "Node Monitor",
      "description": "Full-stack host monitoring plugin: CPU/memory/disk/network metrics (node-exporter compatible), kernel crash detection via /dev/kmsg (dmesg), SSH login auditing with brute-force detection, and system info labels.",
      "author": "openmanager",
      "logo_url": "https://raw.githubusercontent.com/pockyHM/om-plugin-repo/main/om-node-monitor/logo.svg",
      "homepage": "https://github.com/pockyHM/om-plugin-repo",
      "min_agent_version": "0.1.0",
      "message_types": ["metric", "alert", "event", "issue", "error", "labels"],
      "skills": ["linux-ops"],
      "tags": ["monitoring", "system", "cpu", "memory", "disk", "network", "ssh", "dmesg", "security"],
      "config_schema": [
        {
          "name": "metrics_interval",
          "type": "int",
          "description": "Metrics collection interval in seconds",
          "required": false,
          "default": 15
        },
        {
          "name": "labels_interval",
          "type": "int",
          "description": "System labels collection interval in seconds",
          "required": false,
          "default": 300
        },
        {
          "name": "cpu_warn_threshold",
          "type": "float",
          "description": "CPU usage warning threshold (0-100)",
          "required": false,
          "default": 80.0
        },
        {
          "name": "cpu_crit_threshold",
          "type": "float",
          "description": "CPU usage critical threshold (0-100)",
          "required": false,
          "default": 90.0
        },
        {
          "name": "memory_warn_threshold",
          "type": "float",
          "description": "Memory usage warning threshold (0-100)",
          "required": false,
          "default": 80.0
        },
        {
          "name": "memory_crit_threshold",
          "type": "float",
          "description": "Memory usage critical threshold (0-100)",
          "required": false,
          "default": 90.0
        },
        {
          "name": "disk_warn_threshold",
          "type": "float",
          "description": "Disk usage warning threshold (0-100)",
          "required": false,
          "default": 80.0
        },
        {
          "name": "disk_crit_threshold",
          "type": "float",
          "description": "Disk usage critical threshold (0-100)",
          "required": false,
          "default": 90.0
        },
        {
          "name": "ssh_brute_force_threshold",
          "type": "int",
          "description": "SSH failed login attempts threshold for brute-force detection",
